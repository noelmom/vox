<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <key>Label</key>
  <string>com.noelmom.vox</string>

  <key>AssociatedBundleIdentifiers</key>
  <array>
    <string>com.noelmom.vox-server</string>
  </array>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>VOX_APP_SUPPORT/scripts/run.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>VOX_APP_SUPPORT</string>

  <key>StandardOutPath</key>
  <string>VOX_LOG_DIR/vox.log</string>
  <key>StandardErrorPath</key>
  <string>VOX_LOG_DIR/vox-error.log</string>

  <!--
    RunAtLoad = true — the server starts automatically on login.
    Users can disable this from the Vox Helper menu.
  -->
  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>TimeOut</key>
  <integer>120</integer>

  <key>EnvironmentVariables</key>
  <dict>
    <key>VOX_HOST</key>
    <string>0.0.0.0</string>
    <key>VOX_PORT</key>
    <string>8000</string>
    <key>VOX_DEVICE</key>
    <string>auto</string>
  </dict>

</dict>
</plist>

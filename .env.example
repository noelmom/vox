# Vox environment configuration example
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is git-ignored. Never commit secrets to git.
# All variables use the VOX_ prefix unless noted.

# ── Network ───────────────────────────────────────────────────────────────────
# VOX_HOST=0.0.0.0        # 0.0.0.0 = reachable from any device on the network
#                         # 127.0.0.1 = localhost only
# VOX_PORT=8000

# ── Inference ─────────────────────────────────────────────────────────────────
# VOX_DEVICE=auto         # auto | mps | cpu
# VOX_MPS_MEMORY_FRACTION=0.9
#                         # Apple GPU memory allocator cap: 0.9 = stable default,
#                         # 1.0 = maximum recommended MPS memory. Requires restart.

# ── Audio ─────────────────────────────────────────────────────────────────────
# VOX_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# ── Text chunking ─────────────────────────────────────────────────────────────
# VOX_DEFAULT_MAX_CHARS=450
# VOX_MIN_MAX_CHARS=100
# VOX_MAX_MAX_CHARS=3000
# VOX_CHUNK_HEADROOM_CHARS=40

# ── Cleanup ───────────────────────────────────────────────────────────────────
# VOX_OUTPUT_TTL_HOURS=24   # Hours to keep generated output files. 0 = keep forever.
# VOX_CLEANUP_INTERVAL_S=3600

# ── Voice clip limit ──────────────────────────────────────────────────────────
# VOX_MAX_VOICE_CLIP_DURATION_S=120

# ── Input folder watcher ──────────────────────────────────────────────────────
# VOX_WATCHER_INTERVAL_S=10

# ── Hugging Face (no VOX_ prefix — standard HF convention) ───────────────────
# Optional but recommended. Enables authenticated downloads for faster transfer
# rates and access to gated models.
# Generate a read-only token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
